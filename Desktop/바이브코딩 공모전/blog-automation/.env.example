# Anthropic Claude API Key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Blogger Blog ID
BLOGGER_BLOG_ID=6218265260824404297

# Claude model (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Pexels API Key (from https://www.pexels.com/api/new/)
PEXELS_API_KEY=your-pexels-api-key

# Google Custom Search API (CC-licensed images — optional but recommended)
# 1. Enable "Custom Search API" at https://console.cloud.google.com
# 2. Create a Custom Search Engine at https://programmablesearchengine.google.com
#    - "Search the entire web" ON
# 3. Get CX (Search Engine ID) from the CSE control panel
GOOGLE_CSE_KEY=your-google-api-key
GOOGLE_CSE_CX=your-search-engine-id

# ── Tistory ──────────────────────────────────────
# Register app at: https://www.tistory.com/guide/api/manage/register
# Callback URL: http://localhost (any port)
TISTORY_APP_ID=your-tistory-app-id
TISTORY_APP_SECRET=your-tistory-app-secret
TISTORY_BLOG_NAME=your-blog-name   # e.g. "myblog" from myblog.tistory.com

# Category IDs — run: node src/tistory.js --list-categories
TISTORY_CATEGORY_AI_NEWS=0
TISTORY_CATEGORY_PROGRAMS=0
TISTORY_CATEGORY_AI_USAGE=0
